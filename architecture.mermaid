---
title: Sales Operating System — Architecture
---

%%{init: {'theme': 'base', 'themeVariables': {'primaryColor': '#2563eb', 'primaryTextColor': '#fff', 'primaryBorderColor': '#1e40af', 'lineColor': '#64748b', 'secondaryColor': '#f1f5f9', 'tertiaryColor': '#fef3c7'}}}%%

graph TD
    subgraph INGESTION["① DATA INGESTION"]
        WP["WordPress<br/>(Website)"]
        GA["Google Analytics"]
        GM["Gmail"]
        CAL["Calendly"]
        GR["Grain / Zoom"]
        ST["Stripe"]
        BH["Beehive"]
        N8N["n8n<br/>(Orchestrator)"]

        WP --> N8N
        GA --> N8N
        GM --> N8N
        CAL --> N8N
        GR --> N8N
        ST --> N8N
        BH --> N8N
    end

    subgraph CRM["② OPERATIONAL CRM (Write Layer)"]
        CO["Companies<br/>(Law Firms)"]
        CT["Contacts"]
        AC["Activities<br/>(Immutable Log)"]
        OP["Opportunities<br/>(Deals)"]

        CO -->|"1:Many"| CT
        CT -->|"1:Many"| AC
        AC -->|"Feeds"| OP
        CO -->|"1:Many"| OP
    end

    subgraph STAGES["③ SALES STAGE ENFORCEMENT (Gated)"]
        S1["Stage 1: Lead"]
        S2["Stage 2: Sales Working Lead"]
        S3["Stage 3: Opportunity<br/>(Record Created Here)"]
        S4["Stage 4: Evaluation /<br/>Demo / Proposal"]
        S5["Stage 5: Commit"]
        S6W["Stage 6: Closed Won"]
        S6L["Stage 6: Closed Lost"]

        S1 -->|"≥1 activity + qual scheduled"| S2
        S2 -->|"BANT qualified"| S3
        S3 -->|"Demo/proposal delivered"| S4
        S4 -->|"Verbal commitment"| S5
        S5 -->|"Contract signed"| S6W
        S5 -->|"Deal lost"| S6L
        S3 -->|"Deal lost"| S6L
        S4 -->|"Deal lost"| S6L
    end

    subgraph ANALYTICS["④ ANALYTICS LAYER (Read-Only)"]
        FUN["Funnel Metrics<br/>Visitors → MQL → SQL → Opp → Win"]
        PIP["Pipeline Metrics<br/>Value by Stage / Coverage vs Target"]
        PERF["Performance Metrics<br/>AOV / Cycle Length / Activity Correlation"]
        RISK["Risk Indicators<br/>Stale Deals / Inactivity / Slippage"]
    end

    subgraph KNOWLEDGE["⑤ SALES KNOWLEDGE LAYER (Embedded)"]
        DEF["Stage Definitions"]
        QUAL["Qualification Criteria (BANT)"]
        ICP["ICP Logic"]
        RULES["Required-Field Rules"]
    end

    subgraph NOTIFY["⑥ NOTIFICATIONS"]
        SL["Slack Alerts"]
        LM["Loom Links"]
        AI["Claude API<br/>(AI Enrichment)"]
    end

    N8N --> CO
    N8N --> CT
    N8N --> AC

    OP --> STAGES
    STAGES --> ANALYTICS

    KNOWLEDGE -.->|"Enforces"| STAGES
    KNOWLEDGE -.->|"Validates"| CRM

    CRM --> FUN
    CRM --> PIP
    CRM --> PERF
    CRM --> RISK

    N8N --> SL
    N8N --> AI
    STAGES -->|"Stage Change Events"| SL

    style INGESTION fill:#f0f9ff,stroke:#2563eb
    style CRM fill:#f0fdf4,stroke:#16a34a
    style STAGES fill:#fef3c7,stroke:#d97706
    style ANALYTICS fill:#faf5ff,stroke:#9333ea
    style KNOWLEDGE fill:#fef2f2,stroke:#dc2626
    style NOTIFY fill:#f1f5f9,stroke:#64748b
